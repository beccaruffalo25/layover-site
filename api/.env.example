# Copy this file to .env and fill in your values

# Server
PORT=3001

# SQLite database path (defaults to api/subscribers.db)
# DB_PATH=/absolute/path/to/subscribers.db

# Admin key to export subscriber list via GET /api/subscribe?key=<ADMIN_KEY>
ADMIN_KEY=change-me-to-something-secret

# --- Optional: Mailchimp integration ---
# Find your API key at: https://mailchimp.com/help/about-api-keys/
# Your list/audience ID is in Audience → Settings → Audience name and defaults
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
